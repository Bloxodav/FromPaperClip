    conditionKey: true
    onChoiceEventKey: 
    nextNode: {fileID: 11400000, guid: 351e0f7bfea59d34080e6b087bd10c6f, type: 2}
  - choiceText: "\u0411\u0438\u0442\u043A\u043E\u0438\u043D \u0441\u043D\u043E\u0432\u0430
      \u0432\u0437\u043B\u0435\u0442\u0435\u043B."
