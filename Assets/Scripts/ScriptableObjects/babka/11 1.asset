    conditionKey: true
    onChoiceEventKey: 
    nextNode: {fileID: 11400000, guid: 0f9564b17374a9146a4dfaeb05b0e160, type: 2}
  - choiceText: "\u0412\u043D\u0435\u0431\u0440\u0430\u0447\u043D\u044B\u0439 \u0441\u044B\u043D
