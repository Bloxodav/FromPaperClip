  transitions:
  - choiceText: "\u041A\u043E\u043C\u0430\u043D\u0434\u0430 \u201CTeam Spilis\u201D
      \u0437\u0430\u043D\u044F\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0435 \u043C\u0435\u0441\u0442\u043E
