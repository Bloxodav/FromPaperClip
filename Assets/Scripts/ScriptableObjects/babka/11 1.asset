    onChoiceEventKey: 
    nextNode: {fileID: 11400000, guid: f701ad170b3f6744183ab7cecdef3a02, type: 2}
  - choiceText: "\u041A\u0430\u043A\u0438\u0435 \u043F\u043E\u043C\u0438\u0434\u043E\u0440\u044B
