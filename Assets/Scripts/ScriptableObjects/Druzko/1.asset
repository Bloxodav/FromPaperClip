  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  line: "\u0412\u044B \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442\u0435, \u043E
    \u0447\u0451\u043C \u0433\u043E\u0432\u043E\u0440\u044F\u0442 \u044D\u0442\u0438
    \u043B\u044E\u0434\u0438? \u042F - \u043D\u0435\u0442. \u041D\u0435 \u0434\u0443\u043C\u0430\u044E,
    \u0447\u0442\u043E \u0432\u044B, \u043A\u043E\u0433\u0434\u0430-\u043D\u0438\u0431\u0443\u0434\u044C
    \u0432\u0438\u0434\u0435\u043B\u0438 \u0432 \u043D\u0430\u0448\u0435\u043C \u043C\u0438\u0440\u0435
    \u043F\u043E\u0442\u0443\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u0445
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432. \u0414\u0430, \u0444\u0430\u043A\u0442
    \u0438\u0445 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438\u043C\u0435\u0435\u0442 \u043C\u0435\u0441\u0442\u043E \u0431\u044B\u0442\u044C.
    \u041B\u044E\u0434\u0438 \u0432\u0438\u0434\u0435\u043B\u0438 \u043E\u0432\u0446\u0443,
    \u043E\u0447\u0435\u043D\u044C \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u044B.   "
  transitions:
  - choiceText: "\u041E\u0432\u0446\u0430? \u041C\u043D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
      \u044F \u0435\u0451 \u0432\u0438\u0434\u0435\u043B."
    conditionKey: true
    onChoiceEventKey: makeHappy
    nextNode: {fileID: 11400000, guid: 22e035cfbc2563d41b57d58773ebc246, type: 2}
  - choiceText: "\u0412\u044B \u0441\u0443\u043C\u0430\u0441\u0448\u0435\u0434\u0448\u0438\u0439?"
    conditionKey: true
    onChoiceEventKey: makeSad
    nextNode: {fileID: 11400000, guid: b23df51b2ef95734cbde005829e6917e, type: 2}
  - choiceText: "\u0423\u0439\u0442\u0438"
    conditionKey: true
