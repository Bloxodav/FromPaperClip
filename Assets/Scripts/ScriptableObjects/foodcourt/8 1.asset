    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435\u0442."
  transitions:
  - choiceText: "\u042F \u0433\u043E\u0442\u043E\u0432 \u043F\u043E\u043C\u0435\u043D\u044F\u0442\u044C
